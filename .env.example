# ═══════════════════════════════════════════════════════════
#  AI Resume Matcher — Environment Variables
#  Copy to .env and update values for your environment.
# ═══════════════════════════════════════════════════════════

# ── Flask ─────────────────────────────────────────────────
FLASK_ENV=development                      # development | production | testing
SECRET_KEY=change-me-to-a-random-64-char-string   # REQUIRED in production
DEBUG=True

# ── Paths ─────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MODELS_FOLDER=models
LOGS_FOLDER=logs

# ── Upload limits ─────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,doc,txt

# ── NLP / ML ─────────────────────────────────────────────
SPACY_MODEL=en_core_web_sm                 # en_core_web_sm | en_core_web_md
TFIDF_MAX_FEATURES=5000
SVD_N_COMPONENTS=100
SVM_KERNEL=rbf
SIMILARITY_THRESHOLD=0.3

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=DEBUG                             # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/app.log

# ── Session / cookies ────────────────────────────────────
SESSION_LIFETIME_HOURS=24
SESSION_COOKIE_SECURE=False                 # True in production behind HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*                              # comma-separated origins or *

# ── Rate limiting (Flask-Limiter) ─────────────────────────
RATELIMIT_STORAGE_URI=memory://             # use redis://localhost:6379/0 when using Redis

# ── Redis (optional) ───────────────────────────────────────
# Uncomment and set this if you run Redis on a custom host/port.
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ── Gunicorn (production) ─────────────────────────────────
GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
GUNICORN_WORKER_CLASS=gthread

# ── CI / CD secrets (set in GitHub repo settings) ────────
# RAILWAY_TOKEN=                            # Railway deploy token
# RENDER_DEPLOY_HOOK=                       # Render deploy hook URL

# Rate Limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=200 per day,50 per hour
RATELIMIT_STORAGE_URI=memory://

# Gunicorn (Production)
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_BIND=0.0.0.0:5000

# Session
SESSION_LIFETIME_HOURS=24

# Production Settings (uncomment for production)
# FLASK_ENV=production
# SECRET_KEY=<generate-strong-random-key>
# DEBUG=False
# SESSION_COOKIE_SECURE=True
